NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only (Wayfinder Pro). Required for counselor portal, analytics, admin portals, etc.
SUPABASE_SERVICE_ROLE_KEY=
# Wayfinder Pro (staff) — production example: https://wayfinder-pro.thejoshuatree.org
NEXT_PUBLIC_STAFF_APP_URL=http://localhost:3000
# Wayfinder (client) — production example: https://wayfinder.thejoshuatree.org
NEXT_PUBLIC_CLIENT_APP_URL=http://localhost:3001
# Integrated reports app — production TBD (e.g. https://reports.wayfinder-pro.thejoshuatree.org)
NEXT_PUBLIC_REPORTS_APP_URL=http://localhost:3002
# Optional: employer address geocoding and Community Partners map (server token works for both)
MAPBOX_ACCESS_TOKEN=
# Optional: public Mapbox token if you prefer a separate restricted key for the browser map
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
# Optional: web push when staff actions notify users
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:bryan.evans@thejoshuatree.org
