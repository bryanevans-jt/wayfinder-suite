NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Wayfinder Pro (staff) — production example: https://wayfinder-pro.thejoshuatree.org
NEXT_PUBLIC_STAFF_APP_URL=http://localhost:3000
# Wayfinder (client) — production example: https://wayfinder.thejoshuatree.org
NEXT_PUBLIC_CLIENT_APP_URL=http://localhost:3001

# Passkeys (Supabase → Authentication → Passkeys): use parent domain RP ID (e.g. thejoshuatree.org)
# and list both client + staff HTTPS origins so passkeys work on Wayfinder and Wayfinder Pro.

# Web push (run `npm run generate-vapid` from repo root)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:bryan.evans@thejoshuatree.org
