# Supabase — same project as Wayfinder Pro (apps/staff)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Production only — shared sign-in on Wayfinder Pro (do NOT set on the reports Vercel project;
# reports uses host-only cookies so magic-link PKCE does not collide with staff sessions)
# NEXT_PUBLIC_SUPABASE_COOKIE_DOMAIN=.thejoshuatree.org
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cross-app URLs (production)
NEXT_PUBLIC_STAFF_APP_URL=https://wayfinder-pro.thejoshuatree.org
NEXT_PUBLIC_REPORTS_APP_URL=https://wayfinder-reports.thejoshuatree.org

# Google OAuth — Drive, Docs, Gmail (server-only)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Vercel cron auth (set in Vercel env; sent as Bearer token or ?secret=)
CRON_SECRET=your-random-secret-string

# Optional: one-time VPR migration from legacy Google Sheet
VPR_MIGRATION_SHEET_ID=

# Optional: web push for report alert notifications (same keys as staff app)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:bryan.evans@thejoshuatree.org
